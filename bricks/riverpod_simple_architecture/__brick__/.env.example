# Environment template — {{app_title}}
# Copy this file to `.env` and fill values LOCALLY. NEVER commit real values.
# `.env` and the secret files below are gitignored; keep .env.example tracked.
#
# Scope legend:
#   app     = consumed by the Flutter build (only PUBLIC values belong here)
#   backend = server/cloud-function config ONLY — do not ship in the app binary
#   ci      = CI/CD secret store ONLY
#
# Secret backend/ci keys are listed here for completeness but MUST live in
# server/CI config, not in this file or the app. Leave them blank locally.
{{#has_firebase}}

# --- Firebase (app: downloaded config FILES, not values) ---
# android/app/google-services.json          <- download from Firebase console (gitignored)
# ios/Runner/GoogleService-Info.plist       <- download from Firebase console (gitignored)
FIREBASE_PROJECT_ID_DEVELOPMENT=  # backend/public — development Firebase project id
FIREBASE_PROJECT_ID_STAGING=      # backend/public — staging Firebase project id
FIREBASE_PROJECT_ID_PRODUCTION=   # backend/public — production Firebase project id
# FIREBASE_ADMIN_SA_JSON=         # backend/secret — server config only
{{/has_firebase}}
{{#has_supabase}}

# --- Supabase ---
SUPABASE_URL=                     # app/public — project URL
SUPABASE_ANON_KEY=                # app/public — anon key (RLS enforced server-side)
# SUPABASE_SERVICE_ROLE_KEY=      # backend/secret — server config only, NEVER in the app
{{/has_supabase}}
{{#has_msg91}}

# --- MSG91 (OTP + DLT) ---
MSG91_SENDER_ID=                  # backend/public — 6-char DLT-approved header
MSG91_DLT_TEMPLATE_ID=            # backend/public
# MSG91_AUTH_KEY=                 # backend/secret — server config only
{{/has_msg91}}
{{#has_truecaller}}

# --- Truecaller OneTap (Android only) ---
TRUECALLER_APP_KEY=               # app/public
{{/has_truecaller}}
{{#has_appsflyer}}

# --- AppsFlyer ---
APPSFLYER_DEV_KEY=                # app/secret — inject at build time, keep out of VCS
APPSFLYER_IOS_APP_ID=             # app/public — numeric iOS App Store app id
{{/has_appsflyer}}
{{#has_razorpay}}

# --- Razorpay (Android UPI AutoPay) ---
RAZORPAY_KEY_ID=                  # app/public
# RAZORPAY_KEY_SECRET=            # backend/secret — server config only
# RAZORPAY_WEBHOOK_SECRET=        # backend/secret — server config only
{{/has_razorpay}}
{{#has_cashfree}}

# --- Cashfree (Android UPI AutoPay fallback) ---
CASHFREE_APP_ID=                  # app/public
# CASHFREE_SECRET_KEY=            # backend/secret — server config only
# CASHFREE_WEBHOOK_SECRET=        # backend/secret — server config only
{{/has_cashfree}}
{{#has_revenuecat}}

# --- RevenueCat ---
REVENUECAT_PUBLIC_SDK_KEY=        # app/public
# REVENUECAT_SECRET_API_KEY=      # backend/secret — server config only
# REVENUECAT_WEBHOOK_AUTH=        # backend/secret — server config only
{{/has_revenuecat}}
{{#has_onesignal}}

# --- OneSignal ---
ONESIGNAL_APP_ID=                 # app/public
# ONESIGNAL_REST_API_KEY=         # backend/secret — server config only
{{/has_onesignal}}
{{#has_other_providers}}

# --- Other selected providers (add each provider's keys per its docs) ---
{{#other_providers}}
# {{.}}: add this provider's env keys here (see the app's env.md for scopes)
{{/other_providers}}
{{/has_other_providers}}

# --- Google Play Console (ci only) ---
# ANDROID_UPLOAD_KEYSTORE=        # ci/secret
# PLAY_SERVICE_ACCOUNT_JSON=      # ci/secret

# --- Apple / App Store Connect (ci only) ---
APPLE_TEAM_ID=                    # ci/public
# ASC_KEY_ID=                     # ci/secret
# ASC_ISSUER_ID=                  # ci/secret
# ASC_API_PRIVATE_KEY=            # ci/secret (.p8)
